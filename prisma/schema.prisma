generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  name             String?
  email            String          @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  accounts         Account[]
  apiKeys          ApiKey[]
  projects         ProjectMember[]
  sessions         Session[]
  testRuns         TestRun[]       @relation("CreatedBy")
  suiteAssignments TestSuiteCase[] @relation("SuiteCaseAddedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String?
  testCasePrefix  String          @default("TC")
  testCaseCounter Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  apiKeys         ApiKey[]
  defectReports   DefectReport[]
  modules         Module[]
  members         ProjectMember[]
  testCases       TestCase[]
  testRuns        TestRun[]
  testSuites      TestSuite[]

  @@map("projects")
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now())
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Module {
  id        String     @id @default(cuid())
  projectId String
  name      String
  color     String?    @default("#6366f1")
  createdAt DateTime   @default(now())
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCase[]

  @@unique([projectId, name])
  @@map("modules")
}

model TestCase {
  id            String          @id @default(cuid())
  projectId     String
  moduleId      String?
  displayId     String
  jiraKey       String?         @db.VarChar(32)
  title         String          @db.VarChar(200)
  description    String?
  preconditions  String?
  expectedResult String?
  priority       TestPriority    @default(MEDIUM)
  status        TestCaseStatus  @default(DRAFT)
  tags          String[]        @default([])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  module        Module?         @relation(fields: [moduleId], references: [id])
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results       TestResult[]
  suiteItems    TestSuiteCase[]

  @@unique([projectId, displayId])
  @@index([projectId])
  @@index([moduleId])
  @@map("test_cases")
}

model TestRun {
  id          String       @id @default(cuid())
  projectId   String
  createdById String?
  name        String
  source      TestSource
  status      RunStatus    @default(IN_PROGRESS)
  metadata    Json?
  startedAt   DateTime     @default(now())
  completedAt DateTime?
  fileHash    String?
  results     TestResult[]
  createdBy   User?        @relation("CreatedBy", fields: [createdById], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([startedAt])
  @@map("test_runs")
}

model TestResult {
  id             String           @id @default(cuid())
  runId          String
  testCaseId     String?
  name           String
  suite          String?
  status         ResultStatus
  durationMs     Int?
  failureMessage String?
  stackTrace     String?
  category       FailureCategory?
  metadata       Json?
  notes          String?
  attachments    String[]         @default([])
  createdAt      DateTime         @default(now())
  run            TestRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase       TestCase?        @relation(fields: [testCaseId], references: [id])

  @@index([runId])
  @@index([testCaseId])
  @@index([name])
  @@map("test_results")
}

model ApiKey {
  id         String      @id @default(cuid())
  projectId  String
  userId     String
  name       String
  keyHash    String      @unique
  keyPrefix  String
  scope      ApiKeyScope @default(READ_WRITE)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime    @default(now())
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([keyPrefix])
  @@map("api_keys")
}

model TestSuite {
  id          String          @id @default(cuid())
  projectId   String
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  cases       TestSuiteCase[]
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
  @@map("test_suites")
}

model TestSuiteCase {
  id         String    @id @default(cuid())
  suiteId    String
  testCaseId String
  order      Int       @default(0)
  addedById  String?
  addedAt    DateTime  @default(now())
  addedBy    User?     @relation("SuiteCaseAddedBy", fields: [addedById], references: [id])
  suite      TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  testCase   TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([suiteId, testCaseId])
  @@map("test_suite_cases")
}

model DefectReport {
  id                  String   @id @default(cuid())
  projectId           String
  reportedAt          DateTime @default(now())
  requirementsCovered Int      @default(0)
  totalRequirements   Int      @default(0)
  testingBugsFound    Int      @default(0)
  productionBugsFound Int      @default(0)
  notes               String?
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([reportedAt])
  @@map("defect_reports")
}

model ExploratorySession {
  id        String    @id @default(cuid())
  projectId String
  charter   String?
  focus     String?
  notes     String?
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  tags      String[]  @default([])

  @@index([projectId])
  @@map("exploratory_sessions")
}

enum ProjectRole {
  ADMIN
  MEMBER
  VIEWER
}

enum TestPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TestCaseStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

enum TestSource {
  MANUAL
  AUTOMATED
}

enum RunStatus {
  IN_PROGRESS
  COMPLETED
  ABORTED
}

enum ResultStatus {
  PASSED
  FAILED
  SKIPPED
  ERROR
  BLOCKED
}

enum FailureCategory {
  UI
  API
  TIMEOUT
  ASSERTION
  NETWORK
  DATABASE
  UNKNOWN
}

enum ApiKeyScope {
  READ_WRITE
  READ_ONLY
}
